# =============================================
# Configuração da API
# =============================================
PORT=3000
NODE_ENV=development

# =============================================
# JWT — Segredo para assinatura dos tokens
# =============================================
JWT_SECRET=sua_chave_secreta_jwt_mude_em_producao
JWT_EXPIRES_IN=24h

# =============================================
# MongoDB (NoSQL) — Carros, Motos, Marcas de Roupa
# =============================================
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=mongo_password_segura
MONGODB_URI=mongodb://admin:mongo_password_segura@mongodb:27017/api_dual_db?authSource=admin

# =============================================
# PostgreSQL (SQL) — Usuários
# =============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_segura
POSTGRES_DB=api_dual_db
POSTGRES_URI=postgresql://postgres:postgres_password_segura@postgres:5432/api_dual_db
