FROM node:20-alpine

WORKDIR /app

# Copiar arquivos de dependência
COPY package*.json ./

# Instalar todas as dependências (incluindo devDependencies para testes)
RUN npm ci

# Copiar todo o código
COPY src/ ./src/
COPY tests/ ./tests/
COPY jest.config.js ./

# Executar os testes
CMD ["npx", "jest", "--runInBand", "--detectOpenHandles", "--forceExit", "--verbose"]
